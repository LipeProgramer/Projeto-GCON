{
  "version": 2,
  "builds": [
    {
      "src": "registro-imoveis-web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/registro-imoveis-web/index.html"
    },
    {
      "src": "^(.*)$",
      "dest": "/registro-imoveis-web/$1"
    }
  ]
}
